# ─── Variáveis de ambiente — Catálogo Evidências Modas ───
# Copie este arquivo para ".env" (uso local) e preencha os valores reais.
# Em produção (Railway), configure essas mesmas variáveis no painel do serviço
# em Settings → Variables — NUNCA coloque os valores reais neste arquivo no Git.

PORT=3000

# Origem(ns) permitida(s) para CORS. Em produção, recomenda-se restringir à
# URL do frontend (ex: https://catalogo-evidencias.vercel.app) em vez de "*".
CORS_ORIGIN=*

# ─── Autenticação do painel admin ───
# Usuário do admin (e-mail ou nome de usuário, como preferir).
ADMIN_USER=evidenciasmodas26@gmail.com

# Hash bcrypt da senha do admin (NUNCA a senha em texto puro).
# Gere um novo hash com:
#   node -e "console.log(require('bcryptjs').hashSync('SUA_SENHA_AQUI', 12))"
ADMIN_PASS_HASH=$2a$12$4M0YD2ZfEKxf5SPUXwxyz.eVMG2SpS.1uISxIzqLiRh3r.RLBiwo2

# Segredo usado para assinar os tokens JWT de sessão do admin.
# Gere um novo valor único e aleatório com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=GERE_UM_VALOR_UNICO_E_NUNCA_REUTILIZE_ESTE_EXEMPLO
